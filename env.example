# ─── CLERK (Authentication) ────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── STRIPE (Payments) ──────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# https://dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs — create in Stripe Dashboard → Products
STRIPE_PRICE_WILL=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_TRUST=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_COMPLETE=price_xxxxxxxxxxxxxxxxxxxx

# ─── NEON (Database) ────────────────────────────────────────────────────────
# https://console.neon.tech → Your Project → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/clelandlaw?sslmode=require

# ─── RESEND (Transactional Email) ───────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@clelandlaw.com
RESEND_REPLY_TO=ryan@clelandlaw.com

# ─── CLOUDFLARE R2 (Document Storage) ──────────────────────────────────────
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_R2_BUCKET_NAME=cleland-documents
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── APP ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://clelandlaw.com
NEXT_PUBLIC_APP_NAME=Cleland Law

# ─── ADMIN ──────────────────────────────────────────────────────────────────
# Ryan's Clerk user ID — get from Clerk Dashboard → Users after first login
ADMIN_USER_ID=user_xxxxxxxxxxxxxxxxxxxx
